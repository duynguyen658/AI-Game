APP_NAME=Cyber Legends AI Workflow
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./cyber_legends.db

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

N8N_WEBHOOK_SECRET=change-me
APPROVAL_TOKEN_SECRET=change-me

RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

MAX_LLM_CALLS_PER_WORKFLOW=6
MAX_CONTENT_RETRIES=2
MAX_INPUT_CHARACTERS=20000

LOG_LEVEL=INFO