APP_NAME=Cyber Legends AI Workflow
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=3000
BACKEND_BASE_URL=http://localhost:8000
DEMO_AUTH_ENABLED=true
DEMO_SESSION_SECRET=replace-with-at-least-32-random-characters

POSTGRES_DB=cyber_legends
POSTGRES_USER=cyber_legends
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://cyber_legends:change-me@localhost:5432/cyber_legends
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LLM_FALLBACK_PROVIDERS=
LLM_MAX_ESTIMATED_COST=5
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

N8N_WEBHOOK_SECRET=change-me
N8N_TIMESTAMP_TOLERANCE_SECONDS=300
N8N_MAX_BODY_BYTES=1048576
IMAGE_PROVIDER=mock
IMAGE_MODEL=gpt-image-1
MEDIA_STORAGE_ROOT=var/media
MEDIA_MAX_COST=5
MAX_UPLOAD_BYTES=5242880
MAX_CSV_ROWS=50000
MAX_CSV_COLUMNS=100
MAX_DOCUMENT_PAGES=200
ENABLE_REAL_VIDEO_GENERATION=false
APPROVAL_TOKEN_SECRET=change-me
METRICS_TOKEN=change-me

RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

MAX_LLM_CALLS_PER_WORKFLOW=6
MAX_CONTENT_RETRIES=2
MAX_INPUT_CHARACTERS=20000

AGENT_MAX_ITERATIONS=5
AGENT_MAX_LLM_CALLS=5
AGENT_MAX_TOOL_CALLS=8
AGENT_TIMEOUT_SECONDS=90
AGENT_MAX_TOOL_RESULT_CHARACTERS=12000
AGENT_MAX_ACTION_PROPOSALS=3
ACTION_APPROVAL_TTL_SECONDS=3600
ACTION_EXECUTION_TIMEOUT_SECONDS=60
MEMORY_MAX_RESULTS=20
MEMORY_DEFAULT_TTL_DAYS=90

JOB_POLL_INTERVAL_SECONDS=1
JOB_LEASE_SECONDS=60
JOB_HEARTBEAT_SECONDS=15
JOB_MAX_ATTEMPTS=5
JOB_RETRY_BASE_SECONDS=5
JOB_RETRY_MAX_SECONDS=300
JOB_BATCH_SIZE=10
WORKER_STALE_AFTER_SECONDS=120
OUTBOX_LEASE_SECONDS=60
OUTBOX_HEARTBEAT_SECONDS=15
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_BASE_SECONDS=5
OUTBOX_RETRY_MAX_SECONDS=300
MAX_REQUEST_BODY_BYTES=1048576
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cyber-legends-api
OUTBOX_READY_BACKLOG_LIMIT=1000
AUDIT_RETENTION_DAYS=365
APPLICATION_VERSION=1.0.0-rc.1
PROMPT_VERSION=m6
TOOL_REGISTRY_VERSION=m5
POLICY_VERSION=m5
JWT_ISSUER=
JWT_AUDIENCE=

LOG_LEVEL=INFO
